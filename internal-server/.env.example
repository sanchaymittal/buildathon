# Copy this file to `.env` and fill in your secrets.
# The process auto-loads `.env` only if you run it through a tool that
# invokes python-dotenv (already a project dependency). For ad-hoc CLI
# usage, either source the file or export these variables directly.

# ---------- Gemini (required for agent spawning) ------------------------
# Primary key. Pick one of the two; GEMINI_API_KEY takes precedence.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Optional overrides. Defaults: gemini-2.5-flash, no custom endpoint.
# GEMINI_MODEL=gemini-2.5-pro
# GEMINI_API_BASE=

# ---------- GitHub (optional) ------------------------------------------
# Required only for the legacy GitHub-clone deploy flow and /github/* routes.
# GITHUB_TOKEN=
# GITHUB_API_URL=https://api.github.com

# ---------- Docker (optional) ------------------------------------------
# Only required when targeting a remote Docker daemon from the legacy flow.
# DOCKER_BASE_URL=
# DOCKER_TLS_VERIFY=
# DOCKER_CERT_PATH=

# ---------- DevOps config overrides ------------------------------------
# Any config key can be overridden with DEVOPS_<SECTION>__<KEY>=value.
# Examples:
# DEVOPS_GEMINI__MODEL=gemini-2.5-pro
# DEVOPS_AGENT__LOG_FILE=./agent.log
# DEVOPS_GEMINI__MAX_TOOL_CALLS=24
